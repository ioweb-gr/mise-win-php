#!/usr/bin/env bash

set -euo pipefail

VERSION="${ASDF_INSTALL_VERSION}"
INSTALL_PATH="${ASDF_INSTALL_PATH}"

# BASE_URL from the site (redirected version)
BASE_URL="https://downloads.php.net/~windows/releases"

echo "Checking available versions for PHP ${VERSION}..."

find_filename() {
    local url=$1
    # Look for Thread Safe version (no -nts-)
    # The regex matches php-<version>-Win32-.*-x64.zip
    curl -sL "$url" | 
        grep -oE "php-${VERSION}-Win32-.*-x64\.zip" | 
        grep -v "\-nts\-" |
        head -n 1
}

# Try main releases then archives
FILENAME=$(find_filename "${BASE_URL}/") || FILENAME=""

if [ -z "$FILENAME" ]; then
    FILENAME=$(find_filename "${BASE_URL}/archives/") || FILENAME=""
    if [ -n "$FILENAME" ]; then
        DOWNLOAD_URL="${BASE_URL}/archives/${FILENAME}"
    fi
else
    DOWNLOAD_URL="${BASE_URL}/${FILENAME}"
fi

if [ -z "$FILENAME" ]; then
    echo "Error: Could not find PHP version ${VERSION} (Thread Safe, x64) on windows.php.net" >&2
    exit 1
fi

echo "Found release: ${FILENAME}"
echo "Downloading from ${DOWNLOAD_URL}..."

mkdir -p "${INSTALL_PATH}"
TMP_ZIP="${INSTALL_PATH}/php-${VERSION}.zip"

# Download using curl
if ! curl -sL -f -o "${TMP_ZIP}" "${DOWNLOAD_URL}"; then
    echo "Error: Download failed!" >&2
    exit 1
fi

echo "Extracting to ${INSTALL_PATH}..."

# Path conversion for PowerShell if needed
to_win_path() {
    if command -v cygpath >/dev/null 2>&1; then
        cygpath -w "$1"
    else
        # Basic conversion for MSYS2/Git Bash
        echo "$1" | sed -E 's/^\/([a-z])\//\1:\\/; s/\//\\/g'
    fi
}

# Use tar for extraction as it's common in Git Bash / MSYS2 and handles ZIPs
# Some older tar versions on Windows might have issues, so we fallback
if ! tar -xf "${TMP_ZIP}" -C "${INSTALL_PATH}"; then
    echo "Extraction with tar failed. Trying PowerShell..."
    WIN_ZIP=$(to_win_path "${TMP_ZIP}")
    WIN_DEST=$(to_win_path "${INSTALL_PATH}")
    powershell.exe -NoProfile -Command "Expand-Archive -Path '${WIN_ZIP}' -DestinationPath '${WIN_DEST}' -Force"
fi

rm "${TMP_ZIP}"

# Copy php.ini-development to php.ini if it doesn't exist
if [ ! -f "${INSTALL_PATH}/php.ini" ]; then
    if [ -f "${INSTALL_PATH}/php.ini-development" ]; then
        cp "${INSTALL_PATH}/php.ini-development" "${INSTALL_PATH}/php.ini"
        echo "Created default php.ini from php.ini-development"
    fi
fi

echo "PHP ${VERSION} installed successfully!"
