#!/usr/bin/env bash

set -euo pipefail

# Use the redirected URL for stability
BASE_URL="https://downloads.php.net/~windows/releases"

get_versions() {
    local url=$1
    curl -sL "$url" | 
        grep -oE 'php-[0-9]+\.[0-9]+\.[0-9]+-Win32-.*-x64\.zip' | 
        grep -v "\-nts\-" |
        sed -E 's/php-([0-9]+\.[0-9]+\.[0-9]+)-.*/\1/'
}

# Fetch from both current and archives
{
    get_versions "$BASE_URL/"
    get_versions "$BASE_URL/archives/"
} | sort -V | uniq
